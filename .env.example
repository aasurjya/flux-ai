# ─── Claude API (required when USE_REAL_AI=true) ─────────────────────
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# When false (default in dev/test), the AI pipeline short-circuits to a
# deterministic mock so vitest doesn't burn credits and offline development
# stays fast. Set to "true" in production to use real LLM calls.
# REQUIRES ANTHROPIC_API_KEY to be set when true, or getAiClient() throws.
USE_REAL_AI=false

# ─── Storage paths (optional overrides) ───────────────────────────────
# Absolute path to the JSON file that stores projects. Default:
# ./data/projects.json (under the project root). Tests point this at a
# tmpdir fixture to keep runs isolated.
# FLUX_PROJECTS_FILE=

# Absolute path to the directory that holds generated KiCad export zips.
# Default: ./data/exports. Old zips GC to keep only the latest 3 per
# project. Tests use tmpdir here too.
# FLUX_EXPORTS_DIR=
